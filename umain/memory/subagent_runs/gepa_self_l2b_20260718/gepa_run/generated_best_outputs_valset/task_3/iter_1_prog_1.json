                "critical": false,
                "quote": "\u6839\u636e\u8d8a\u5357\u56fd\u5bb6\u94f6\u884c\u6570\u636e\uff0c2023\u5e74\u975e\u73b0\u91d1\u652f\u4ed8\u4ea4\u6613\u91cf\u540c\u6bd4\u589e\u957f\u8d85\u8fc750%",
