                "problem": "\u7ed3\u8bba4\u7684\u2018\u63a8\u65ad\u2019\u90e8\u5206\u672a\u660e\u786e\u533a\u5206\u4e8b\u5b9e\u4e0e\u63a8\u65ad\uff0c\u4e14\u7f6e\u4fe1\u5ea6\u6807\u6ce8\u4e3a\u2018\u4e2d\u2019\uff0c\u4f46\u7f3a\u4e4f\u5bf9COD\u4efd\u989d\u4e0b\u964d\u901f\u5ea6\u7684\u5177\u4f53\u63a8\u5bfc\uff08\u5982\u4ece40-50%\u964d\u81f320-30%\u7684\u8def\u5f84\uff09\u3002",
                "fix": "\u589e\u52a0\u63a8\u5bfc\u6b65\u9aa4\uff1a\u5047\u8bbeCOD\u5360\u6bd4\u6bcf\u5e74\u4e0b\u964d5\u4e2a\u767e\u5206\u70b9\uff0c\u4ece2023\u5e7445%\u964d\u81f32026\u5e7430%\uff0c\u5e76\u8bf4\u660e\u4e0b\u964d\u901f\u5ea6\u53d7\u4fe1\u4efb\u5efa\u7acb\u548c\u653f\u7b56\u63a8\u52a8\u5f71\u54cd\u3002"
            },
            {
                "dim": "rigor",
                "critical": false,
                "quote": "\u7269\u6d41\u6210\u672c\u5360GDP\u6bd4\u91cd\u7ea6\u4e3a20%\uff0c\u9ad8\u4e8e\u6cf0\u56fd\uff08\u7ea615%\uff09\u548c\u9a6c\u6765\u897f\u4e9a\uff08\u7ea613%\uff09",
                "problem": "\u5f15\u7528\u7684\u7269\u6d41\u6210\u672c\u6570\u636e\uff0820%\uff09\u6765\u81ea\u4e16\u754c\u94f6\u884cLPI\u62a5\u544a\uff0c\u4f46\u8be5\u62a5\u544a\u672a\u76f4\u63a5\u63d0\u4f9b\u2018\u7269\u6d41\u6210\u672c\u5360GDP\u6bd4\u91cd\u2019\u6307\u6807\uff0c\u53ef\u80fd\u6df7\u6dc6\u4e86LPI\u8bc4\u5206\u4e0e\u6210\u672c\u6570\u636e\u3002",
                "fix": "\u6838\u5b9e\u6765\u6e90\uff1a\u786e\u8ba4\u4e16\u754c\u94f6\u884cLPI\u62a5\u544a\u662f\u5426\u5305\u542b\u8be5\u6307\u6807\uff0c\u6216\u6539\u7528\u8d8a\u5357\u7269\u6d41\u534f\u4f1a\uff08VLA\uff09\u7b49\u672c\u5730\u673a\u6784\u53d1\u5e03\u7684\u7269\u6d41\u6210\u672c\u6570\u636e\u3002"
